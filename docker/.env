# DreamZero + Isaac Sim Docker Configuration
# Adjust these paths for your Lambda Cloud instance

# GPU Configuration (GH200 = single GPU shared between containers)
NVIDIA_VISIBLE_DEVICES=all

# DreamZero Inference
DREAMZERO_PORT=8000
NUM_INFERENCE_GPUS=1
MODEL_PATH=/checkpoints/dreamzero_franka_orca_lora
WAN_CKPT_DIR=/checkpoints/Wan2.1-I2V-14B-480P
TOKENIZER_DIR=/checkpoints/umt5-xxl
ATTENTION_BACKEND=TE
ENABLE_DIT_CACHE=true

# Host paths (Lambda instance layout: ~/Dreamzero/{repo,data,checkpoints,output})
DREAMZERO_REPO=/home/ubuntu/Dreamzero/repo
HOST_CHECKPOINT_DIR=/home/ubuntu/Dreamzero/checkpoints
HOST_DATA_DIR=/home/ubuntu/Dreamzero/data
HOST_OUTPUT_DIR=/home/ubuntu/Dreamzero/output

# Isaac Sim
ISAAC_SIM_HEADLESS=true
LIVESTREAM_PORT=8211
LIVESTREAM_DATA_PORT=49100

# Training
TRAINING_BASE_IMAGE=nvcr.io/nvidia/pytorch:24.12-py3
HF_TOKEN=
WANDB_API_KEY=
NUM_GPUS=

# Eval Configuration
EVAL_INSTRUCTION="pick up the object"
EVAL_EPISODES=10
EVAL_OPEN_LOOP_HORIZON=24
